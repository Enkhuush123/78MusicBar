generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Event {
  id            String        @id @default(uuid())
  title         String
  description   String?
  djName        String?
  djType        String?
  imageUrl      String?
  price         Int           @default(0)
  currency      String        @default("MNT")
  venue         String        @default("78MusicBar")
  startsAt      DateTime
  endsAt        DateTime?
  isPublished   Boolean       @default(true)
  isFeatured    Boolean       @default(false) 
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  HomeFeaturedEvent HomeFeaturedEvent[]

  reservations  Reservation[]

  @@index([startsAt])
  @@index([isFeatured])
}

model HomeHero {
  id          String   @id @default(uuid())
  imageUrl    String
  headline    String   @default("Эвентүүд, тав тухтай орчин")
  subheadline String   @default("Ширээгээ урьдчилж захиалаарай.")
  ctaText     String   @default("Эвентүүд үзэх")
  ctaHref     String   @default("/events")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
}

model HomeImage {
  id        String   @id @default(uuid())
  imageUrl  String
  sort      Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sort])
}
model Reservation {
  id          String   @id @default(uuid())

  eventId     String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  name        String?
  phone       String?

  userId      String?
  userEmail   String?
  userPhone   String?

  guests      Int      @default(2)
  reservedFor DateTime
  tableNo     Int
  surchargeAmount Int   @default(0)
  note        String?
  status      String   @default("new")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([eventId, reservedFor, tableNo])
  @@index([eventId])
  @@index([reservedFor])
  @@index([userId])
}
enum MenuCategory {
  drinks
  food
}

model MenuImage {
  id        String       @id @default(uuid())
  category  MenuCategory
  imageUrl  String
  sort      Int          @default(0)
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([category, sort])
}

model SitePage {
  id        String   @id @default(uuid())
  slug      String   @unique
  title     String
  body      String   @default("") 
  imageUrl  String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}
model HomeFeaturedEvent {
  id        String   @id @default(uuid())

  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  sort      Int      @default(0)
  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([eventId])
  @@index([isActive, sort])
}

model Review {
  id          String   @id @default(uuid())
  userId      String?
  userEmail   String?
  displayName String
  comment     String
  rating      Int      @default(5)
  isApproved  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isApproved, createdAt])
}

model CollectionCategory {
  id        String   @id @default(uuid())
  nameEn    String
  nameMn    String
  sort      Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  items     CollectionItem[]

  @@index([isActive, sort])
}

model CollectionItem {
  id         String             @id @default(uuid())
  categoryId String
  category   CollectionCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  nameEn     String
  nameMn     String
  infoEn     String
  infoMn     String
  imageUrl   String?
  sort       Int                @default(0)
  isActive   Boolean            @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId, isActive, sort])
}

enum OpenDeckStatus {
  pending
  approved
  rejected
  cancelled
}

model OpenDeckReservation {
  id            String         @id @default(uuid())
  slotId        String?        @unique
  slot          OpenDeckSlot?  @relation(fields: [slotId], references: [id], onDelete: Cascade)
  userId        String?
  userEmail     String?
  requesterName String
  phone         String
  djName        String
  genre         String
  setDuration   Int            @default(60)
  preferredDate DateTime
  preferredTime String?
  socialUrl     String?
  note          String?
  status        OpenDeckStatus @default(pending)
  adminNote     String?
  approvedAt    DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([status, preferredDate])
  @@index([createdAt])
  @@index([userId])
  @@index([userEmail])
  @@index([slotId])
}

model OpenDeckDay {
  id        String         @id @default(uuid())
  eventDate DateTime       @unique
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  slots     OpenDeckSlot[]

  @@index([eventDate, isActive])
}

model OpenDeckSlot {
  id        String               @id @default(uuid())
  dayId     String
  day       OpenDeckDay          @relation(fields: [dayId], references: [id], onDelete: Cascade)
  startsAt  DateTime
  endsAt    DateTime
  sort      Int                  @default(0)
  isOpen    Boolean              @default(true)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  reservation OpenDeckReservation?

  @@unique([dayId, sort])
  @@index([dayId, startsAt, isOpen])
}
